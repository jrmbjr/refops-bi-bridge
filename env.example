PORT=3000

# Chave forte aleatória (use: openssl rand -hex 32)
BRIDGE_API_KEY=troque-por-uma-chave-aleatoria-forte

# Credenciais SQL Server da Blue Fleet BI
SQLSERVER_HOST=seu-host.database.windows.net
SQLSERVER_PORT=1433
SQLSERVER_DB=BluefleetBI
SQLSERVER_USER=usuario
SQLSERVER_PASSWORD=senha

# TLS
SQLSERVER_ENCRYPT=true
SQLSERVER_TRUST_CERT=true
